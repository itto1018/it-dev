{
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Read(.env.*)",
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(**/secrets/**)",
      "Bash(wget:*)"
    ],
    "allow": [
      "Bash(pnpm test)",
      "Bash(gh pr view:*)"
    ]
  },
  "mcpServers": {
    "playwright": {
      "url": "http://playwright_mcp:8931/mcp"
    }
  }
}