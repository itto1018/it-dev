FROM node:25-bullseye-slim

# Set the working directory
WORKDIR /app

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Set environment variable for Claude Code configuration directory
ENV CLAUDE_CONFIG_DIR=/root/.config/claude-code
RUN mkdir -p /root/.config/claude-code

# Start the Claude Code server
ENTRYPOINT ["claude"]