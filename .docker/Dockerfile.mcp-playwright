FROM node:25-bullseye-slim

# Set the working directory
WORKDIR /mcp-playwright

# Install @playwright/mcp globally (avoid npx auto-install warning)
RUN npm install -g @playwright/mcp

# Install Playwright system dependencies for headless Chromium
RUN npx playwright install --with-deps chromium

# Expose the port the app runs on
EXPOSE 3001

# Start the MCP server
CMD ["playwright-mcp", "--headless", "--isolated", "--browser", "chromium", "--no-sandbox"]